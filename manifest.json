{
  "manifest_version": 3,
  "name": "Concise - Tab Organiser",
  "description": "Named workspaces for Chrome windows",
  "version": "0.2.0",
  "permissions": ["tabs", "storage", "windows"],
  "action": {},
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {},
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Concise"
    }
  }
}
