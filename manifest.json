{
  "manifest_version": 3,
  "name": "Concise - Tab Organiser",
  "description": "Named workspaces for Chrome windows",
  "version": "0.2.0",
  "permissions": ["tabs", "storage", "windows", "alarms"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Concise"
    }
  }
}
